{
  "resourceType": "CapabilityStatement",
  "id": "example-conformance",
  "url": "https://example.org/CapabilityStatement/example-conformance",
  "version": "1.0.0",
  "name": "ExampleConformance",
  "status": "active",
  "date": "2024-01-01",
  "publisher": "Your Organization",
  "description": "Conformance requirements defining which profiles to validate against",
  "kind": "requirements",
  "fhirVersion": "4.0.1",
  "format": [
    "application/fhir+json",
    "application/fhir+xml"
  ],
  "rest": [
    {
      "mode": "server",
      "resource": [
        {
          "type": "Patient",
          "profile": "https://example.org/StructureDefinition/example-patient"
        },
        {
          "type": "Observation",
          "profile": "https://example.org/StructureDefinition/example-observation"
        },
        {
          "type": "Condition",
          "profile": "https://example.org/StructureDefinition/example-condition"
        }
      ]
    }
  ]
}
